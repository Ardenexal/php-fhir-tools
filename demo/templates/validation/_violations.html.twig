{% set colorMap = {
    'error':   {border: 'border-red-200',   bg: 'bg-red-50',   text: 'text-red-800',   chip: 'bg-red-100 text-red-600'},
    'warning': {border: 'border-amber-200', bg: 'bg-amber-50', text: 'text-amber-800', chip: 'bg-amber-100 text-amber-600'},
    'info':    {border: 'border-blue-200',  bg: 'bg-blue-50',  text: 'text-blue-800',  chip: 'bg-blue-100 text-blue-600'},
} %}
{% set colors = colorMap[severity] ?? colorMap['error'] %}

<ul class="space-y-2">
    {% for violation in violations %}
    <li class="rounded-lg border {{ colors.border }} {{ colors.bg }} px-4 py-3">
        <div class="flex flex-wrap items-start gap-2">
            <span class="font-mono text-xs font-semibold {{ colors.text }} shrink-0">{{ violation.path ?: '(root)' }}</span>
            <span class="text-xs {{ colors.chip }} px-1.5 py-0.5 rounded font-mono shrink-0">
                {{ violation.constraintClass|split('\\')|last }}
            </span>
        </div>
        <p class="mt-1 text-sm {{ colors.text }}">{{ violation.message }}</p>
    </li>
    {% endfor %}
</ul>
