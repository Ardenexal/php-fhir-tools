{
    "name": "ardenexal/fhir-code-generation",
    "description": "FHIR code generation component for PHP FHIRTools",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "FHIR Tools Contributors",
            "email": "contributors@fhirtools.dev"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.3",
        "ext-zip": "*",
        "amphp/http-client": "^5.3.4",
        "ardenexal/fhir-metadata": "^0.4",
        "composer/semver": "^3.4.4",
        "nette/php-generator": "^4.1",
        "psr/log": "^1|^2|^3",
        "symfony/console": "^6.4|^7.4",
        "symfony/dependency-injection": "^6.4|^7.4",
        "symfony/filesystem": "^6.4|^7.4",
        "symfony/finder": "^6.4|^7.4",
        "symfony/http-client-contracts": "^3.4",
        "symfony/intl": "^6.4|^7.0",
        "symfony/string": "^6.4|^7.0",
        "symfony/validator": "^6.4|^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5",
        "giorgiosironi/eris": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Ardenexal\\FHIRTools\\Component\\CodeGeneration\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ardenexal\\FHIRTools\\Component\\CodeGeneration\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.4.x-dev"
        }
    }
}
